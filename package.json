{
  "name": "@org/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start:host-v4": "npx nx serve host-v4",
    "start:host-v5": "npx nx serve host-v5",
    "start:remote-v4": "npx nx serve remoteV4",
    "start:remote-v5": "npx nx serve remoteV5",
    "build:host-v4": "npx nx build host-v4",
    "build:host-v5": "npx nx build host-v5",
    "build:remote-v4": "npx nx build remoteV4",
    "build:remote-v5": "npx nx build remoteV5",
    "build:all": "npx nx run-many --target=build --all",
    "lint:all": "npx nx run-many --target=lint --all",
    "graph": "npx nx graph",
    "deploy:host-v4": "npx nx build host-v4 && npx firebase deploy --only hosting:host-v4",
    "deploy:host-v5": "npx nx build host-v5 && npx firebase deploy --only hosting:host-v5",
    "deploy:remote-v4": "npx nx build remoteV4 && npx firebase deploy --only hosting:remote-v4",
    "deploy:remote-v5": "npx nx build remoteV5 && npx firebase deploy --only hosting:remote-v5",
    "deploy:all": "npm run build:all && npx firebase deploy --only hosting"
  },
  "private": true,
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "~2.1.2",
    "@analogjs/vitest-angular": "~2.1.2",
    "@angular-devkit/build-angular": "~21.1.0",
    "@angular-devkit/core": "~21.1.0",
    "@angular-devkit/schematics": "~21.1.0",
    "@angular/build": "~21.1.0",
    "@angular/cli": "~21.1.0",
    "@angular/compiler-cli": "~21.1.0",
    "@angular/language-service": "~21.1.0",
    "@eslint/js": "^9.8.0",
    "@module-federation/enhanced": "^0.21.2",
    "@nx/angular": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/module-federation": "22.5.4",
    "@nx/vitest": "22.5.4",
    "@nx/web": "22.5.4",
    "@nx/webpack": "22.5.4",
    "@schematics/angular": "~21.1.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "20.19.9",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/ui": "^4.0.8",
    "angular-eslint": "^21.0.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "firebase-tools": "^13.29.1",
    "jsdom": "^27.1.0",
    "nx": "22.5.1",
    "prettier": "^2.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.8"
  },
  "workspaces": [
    "packages/*",
    "apps/hosts/*",
    "apps/remotes/*"
  ],
  "dependencies": {
    "@angular/animations": "~21.1.0",
    "@angular/common": "~21.1.0",
    "@angular/compiler": "~21.1.0",
    "@angular/core": "~21.1.0",
    "@angular/forms": "~21.1.0",
    "@angular/platform-browser": "~21.1.0",
    "@angular/router": "~21.1.0",
    "rxjs": "~7.8.0"
  }
}
